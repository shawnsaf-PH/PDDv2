<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PDD v2"
    Height="700"
    Width="1000">

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">

            <TextBlock
                Text="Toolboxes"
                FontWeight="Bold"
                Margin="0,0,0,10"/>

            <CheckBox Content="Basic"/>
            <CheckBox Content="Option"/>
            <CheckBox Content="Site"/>
            <CheckBox Content="Custom"/>
            <CheckBox Content="Prep"/>
            <CheckBox Content="Zeppelin"/>
            <CheckBox Content="Global Site"/>

        </StackPanel>

        <DockPanel Grid.Column="1">

            <TextBox
                Name="SearchBox"
                Height="25"
                Margin="0,0,0,10"
                DockPanel.Dock="Top"/>

            <ListBox
                Name="ApplicationList"/>

        </DockPanel>

    </Grid>
</Window>